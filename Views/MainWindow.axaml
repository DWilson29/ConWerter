<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ConWerter.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ConWerter.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="ConWerter">

	<Design.DataContext>
		<!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
		<vm:MainWindowViewModel/>
	</Design.DataContext>
	<TabControl Margin="5">
		<TabItem Header="Phrase to CW">
			<Grid RowDefinitions="Auto, *, Auto, *" Margin="10" x:Name="PhToCW">
				<TextBlock Grid.Row="0"> Enter your phrase to convert to CW</TextBlock>
				<TextBox Grid.Row="1" Margin="5" Text="{Binding Phrase, Mode=TwoWay}>" Name="PhraseInput"></TextBox>
				<Grid Grid.Row="2" ColumnDefinitions="Auto, *, *" Margin="10">
					<Button Grid.Column="0" Margin="5" Padding="5" HorizontalAlignment="Center" HotKey="Enter" Command="{Binding ConvertPhraseCommand}">Play</Button>
					<Slider Grid.Column="1" Margin="10" Value="{Binding Volume}" />
					<Slider Grid.Column="2" Margin="10" Value="{Binding Speed}" />
				</Grid>
				<Border Grid.Row="3" BorderBrush="White" BorderThickness="2" Margin="5">
					<TextBlock Text="{Binding CwOutput, Mode=TwoWay}>" Name="CwOutput"></TextBlock>
				</Border>
			</Grid>
		</TabItem>
		<TabItem Header ="CW to Phrase">
			<Grid RowDefinitions="Auto, *, Auto, *" Margin="10" x:Name="CWToPh">
				<TextBlock Grid.Row="0">Enter your CW to convert to text</TextBlock>
				<TextBox Grid.Row="1" Margin="5" Text="{Binding Cw, Mode=TwoWay}>" Name="CwInput"></TextBox>
				<Button Grid.Row="2" Margin="5" HorizontalAlignment="Center" HotKey="Enter" Command="{Binding ConvertCwCommand}">Convert</Button>
				<Border Grid.Row="3" BorderBrush="White" BorderThickness="2" Margin="5">
					<TextBlock Text="{Binding PhraseOutput, Mode=TwoWay}>" Name="PhraseOutput"></TextBlock>
				</Border>
			</Grid>
		</TabItem>
	</TabControl>
</Window>
