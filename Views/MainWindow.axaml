<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ConWerter.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ConWerter.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="ConWerter">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>
	<Grid RowDefinitions="Auto, *, Auto"
          x:Name="Root">
		<StackPanel Grid.Row="1">
			<TextBlock>Enter your phrase to convert to CW</TextBlock>
			<TextBox Text="" Name="Phrase"></TextBox>
			<Button HorizontalAlignment="Center" HotKey="Enter" Click="Button_Phrase">Play</Button>
		</StackPanel>

		<StackPanel Grid.Row="2">
			<TextBlock>Enter your CW to convert to english</TextBlock>
			<TextBox Text="" Name="CW"></TextBox>
			<Button HorizontalAlignment="Center" HotKey="Enter" Click="Button_Cw">Play</Button>
		</StackPanel>
	</Grid>

</Window>
